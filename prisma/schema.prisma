generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String   @map("password_hash")
  role         String
  status       String   @default("active")
  teacher      Teacher?
  student      Student?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Teacher {
  id           String        @id @default(uuid())
  userId       String?       @unique @map("user_id")
  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  phone        String?
  email        String?
  avatarUrl    String?       @map("avatar_url")
  status       String        @default("active")
  deletedAt    DateTime?     @map("deleted_at")
  classes      Class[]
  courses      Course[]
  courseGroups CourseGroup[]
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  @@map("teachers")
}

model Class {
  id        String             @id @default(uuid())
  name      String
  grade     String
  subject   String
  teacherId String?            @map("teacher_id")
  teacher   Teacher?           @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  status    String             @default("active")
  deletedAt DateTime?          @map("deleted_at")
  students  Student[]
  sessions  ClassroomSession[]
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  @@map("classes")
}

model Student {
  id                     String                         @id @default(uuid())
  userId                 String?                        @unique @map("user_id")
  user                   User?                          @relation(fields: [userId], references: [id], onDelete: SetNull)
  name                   String
  classId                String                         @map("class_id")
  class                  Class                          @relation(fields: [classId], references: [id], onDelete: Cascade)
  studentNo              String?                        @map("student_no")
  attendance             String?
  practiceCount          Int                            @default(0) @map("practice_count")
  status                 String                         @default("active")
  deletedAt              DateTime?                      @map("deleted_at")
  answers                StudentAnswer[]
  courseEnrollments      StudentCourseEnrollment[]
  courseGroupEnrollments StudentCourseGroupEnrollment[]
  learningProfiles       LearningProfile[]
  parentSummaries        ParentSummary[]
  createdAt              DateTime                       @default(now()) @map("created_at")
  updatedAt              DateTime                       @updatedAt @map("updated_at")

  @@map("students")
}

model Course {
  id                  String                    @id @default(uuid())
  teacherId           String?                   @map("teacher_id")
  teacher             Teacher?                  @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  groupId             String?                   @map("group_id")
  group               CourseGroup?              @relation(fields: [groupId], references: [id], onDelete: SetNull)
  title               String
  subject             String
  grade               String
  description         String?
  duration            String?
  goal                String?
  knowledge           Json?
  hasOutline          Boolean                   @default(false) @map("has_outline")
  progress            Int                       @default(18)
  materialUploaded    Boolean                   @default(false) @map("material_uploaded")
  materialName        String?                   @map("material_name")
  referencedMaterials Json                      @default("[]") @map("referenced_materials")
  outline             Json?
  mindmap             Json?
  ppt                 Json?
  lessonPlan          Json?                     @map("lesson_plan")
  unitType            String                    @default("lesson") @map("unit_type")
  sortOrder           Int                       @default(0) @map("sort_order")
  status              String                    @default("active")
  deletedAt           DateTime?                 @map("deleted_at")
  knowledgePoints     KnowledgePoint[]
  questions           Question[]
  sessions            ClassroomSession[]
  studentEnrollments  StudentCourseEnrollment[]
  learningProfiles    LearningProfile[]
  parentSummaries     ParentSummary[]
  createdAt           DateTime                  @default(now()) @map("created_at")
  updatedAt           DateTime                  @updatedAt @map("updated_at")

  @@map("courses")
}

model CourseGroup {
  id                 String                         @id @default(uuid())
  teacherId          String?                        @map("teacher_id")
  teacher            Teacher?                       @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  title              String
  subject            String
  grade              String
  description        String?
  knowledgeGraph     Json?                          @map("knowledge_graph")
  status             String                         @default("active")
  deletedAt          DateTime?                      @map("deleted_at")
  units              Course[]
  studentEnrollments StudentCourseGroupEnrollment[]
  createdAt          DateTime                       @default(now()) @map("created_at")
  updatedAt          DateTime                       @updatedAt @map("updated_at")

  @@map("course_groups")
}

model QuestionBank {
  id              String                     @id @default(uuid())
  title           String
  subject         String
  grade           String?
  usage           String?
  description     String?
  tags            Json                       @default("[]")
  graphRevision   Int                        @default(0) @map("graph_revision")
  status          String                     @default("active")
  deletedAt       DateTime?                  @map("deleted_at")
  questions       Question[]
  knowledgePoints KnowledgePoint[]
  relations       KnowledgeRelation[]
  layouts         KnowledgeGraphNodeLayout[]
  createdAt       DateTime                   @default(now()) @map("created_at")
  updatedAt       DateTime                   @updatedAt @map("updated_at")

  @@map("question_banks")
}

model KnowledgePoint {
  id                String                     @id @default(uuid())
  courseId          String?                    @map("course_id")
  course            Course?                    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  bankId            String?                    @map("bank_id")
  bank              QuestionBank?              @relation(fields: [bankId], references: [id], onDelete: Cascade)
  name              String
  canonicalKey      String?                    @map("canonical_key")
  aliases           Json                       @default("[]")
  category          String?
  description       String?
  source            String                     @default("ai")
  status            String                     @default("active")
  manualLocked      Boolean                    @default(false) @map("manual_locked")
  parentId          String?                    @map("parent_id")
  parent            KnowledgePoint?            @relation("KnowledgePointTree", fields: [parentId], references: [id])
  children          KnowledgePoint[]           @relation("KnowledgePointTree")
  mergedIntoId      String?                    @map("merged_into_id")
  mergedInto        KnowledgePoint?            @relation("KnowledgePointMerge", fields: [mergedIntoId], references: [id], onDelete: SetNull)
  mergedFrom        KnowledgePoint[]           @relation("KnowledgePointMerge")
  questions         QuestionKnowledgePoint[]
  outgoingRelations KnowledgeRelation[]        @relation("KnowledgeRelationSource")
  incomingRelations KnowledgeRelation[]        @relation("KnowledgeRelationTarget")
  layouts           KnowledgeGraphNodeLayout[]

  @@unique([bankId, canonicalKey])
  @@index([bankId, status])
  @@map("knowledge_points")
}

model Question {
  id                  String                       @id @default(uuid())
  bankId              String?                      @map("bank_id")
  bank                QuestionBank?                @relation(fields: [bankId], references: [id], onDelete: SetNull)
  courseId            String?                      @map("course_id")
  course              Course?                      @relation(fields: [courseId], references: [id], onDelete: SetNull)
  type                String
  stage               String?
  difficulty          String
  title               String
  options             Json?
  answer              Json
  analysis            String?
  knowledge           Json?
  status              String                       @default("active")
  deletedAt           DateTime?                    @map("deleted_at")
  accuracy            Int?
  avgTimeSeconds      Int?                         @map("avg_time_seconds")
  weakPoint           String?                      @map("weak_point")
  optionDistribution  Json?                        @map("option_distribution")
  knowledgePoints     QuestionKnowledgePoint[]
  knowledgeExtraction QuestionKnowledgeExtraction?
  relationEvidence    KnowledgeRelationEvidence[]
  sessionLinks        ClassroomSessionQuestion[]
  answers             StudentAnswer[]
  createdAt           DateTime                     @default(now()) @map("created_at")
  updatedAt           DateTime                     @updatedAt @map("updated_at")

  @@map("questions")
}

model QuestionKnowledgePoint {
  questionId       String         @map("question_id")
  knowledgePointId String         @map("knowledge_point_id")
  question         Question       @relation(fields: [questionId], references: [id], onDelete: Cascade)
  knowledgePoint   KnowledgePoint @relation(fields: [knowledgePointId], references: [id], onDelete: Cascade)
  source           String         @default("explicit")
  confidence       Float?
  manualLocked     Boolean        @default(false) @map("manual_locked")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @default(now()) @updatedAt @map("updated_at")

  @@id([questionId, knowledgePointId])
  @@map("question_knowledge_points")
}

model KnowledgeRelation {
  id            String                      @id @default(uuid())
  bankId        String                      @map("bank_id")
  bank          QuestionBank                @relation(fields: [bankId], references: [id], onDelete: Cascade)
  sourcePointId String                      @map("source_point_id")
  sourcePoint   KnowledgePoint              @relation("KnowledgeRelationSource", fields: [sourcePointId], references: [id], onDelete: Cascade)
  targetPointId String                      @map("target_point_id")
  targetPoint   KnowledgePoint              @relation("KnowledgeRelationTarget", fields: [targetPointId], references: [id], onDelete: Cascade)
  type          String
  label         String
  source        String
  confidence    Float?
  supportCount  Int                         @default(0) @map("support_count")
  manualLocked  Boolean                     @default(false) @map("manual_locked")
  status        String                      @default("active")
  evidence      KnowledgeRelationEvidence[]
  createdAt     DateTime                    @default(now()) @map("created_at")
  updatedAt     DateTime                    @updatedAt @map("updated_at")

  @@unique([bankId, sourcePointId, targetPointId, type])
  @@index([bankId, status])
  @@map("knowledge_relations")
}

model KnowledgeRelationEvidence {
  relationId   String            @map("relation_id")
  questionId   String            @map("question_id")
  relation     KnowledgeRelation @relation(fields: [relationId], references: [id], onDelete: Cascade)
  question     Question          @relation(fields: [questionId], references: [id], onDelete: Cascade)
  evidenceType String            @map("evidence_type")
  createdAt    DateTime          @default(now()) @map("created_at")

  @@id([relationId, questionId])
  @@map("knowledge_relation_evidence")
}

model QuestionKnowledgeExtraction {
  questionId    String    @id @map("question_id")
  question      Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  contentHash   String    @map("content_hash")
  status        String    @default("pending")
  promptVersion String    @default("v1") @map("prompt_version")
  provider      String?
  model         String?
  attempts      Int       @default(0)
  errorMessage  String?   @map("error_message")
  analyzedAt    DateTime? @map("analyzed_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([status, updatedAt])
  @@map("question_knowledge_extractions")
}

model KnowledgeGraphNodeLayout {
  bankId           String         @map("bank_id")
  knowledgePointId String         @map("knowledge_point_id")
  bank             QuestionBank   @relation(fields: [bankId], references: [id], onDelete: Cascade)
  knowledgePoint   KnowledgePoint @relation(fields: [knowledgePointId], references: [id], onDelete: Cascade)
  x                Float
  y                Float
  pinned           Boolean        @default(true)
  updatedAt        DateTime       @updatedAt @map("updated_at")

  @@id([bankId, knowledgePointId])
  @@map("knowledge_graph_node_layouts")
}

model ClassroomSession {
  id                 String                     @id @default(uuid())
  classId            String                     @map("class_id")
  courseId           String                     @map("course_id")
  targetStudentId    String?                    @map("target_student_id")
  class              Class                      @relation(fields: [classId], references: [id], onDelete: Cascade)
  course             Course                     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title              String
  status             String
  answers            StudentAnswer[]
  sessionQuestions   ClassroomSessionQuestion[]
  studentEnrollments StudentCourseEnrollment[]
  startedAt          DateTime?                  @map("started_at")
  endedAt            DateTime?                  @map("ended_at")

  @@map("classroom_sessions")
}

model ClassroomSessionQuestion {
  sessionId  String           @map("session_id")
  questionId String           @map("question_id")
  sortOrder  Int              @default(0) @map("sort_order")
  session    ClassroomSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question   Question         @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@id([sessionId, questionId])
  @@map("classroom_session_questions")
}

model StudentCourseEnrollment {
  id        String            @id @default(uuid())
  studentId String            @map("student_id")
  courseId  String            @map("course_id")
  sessionId String?           @unique @map("session_id")
  student   Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course    Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  session   ClassroomSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  status    String            @default("active")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  @@unique([studentId, courseId])
  @@map("student_course_enrollments")
}

model StudentCourseGroupEnrollment {
  id        String      @id @default(uuid())
  studentId String      @map("student_id")
  groupId   String      @map("group_id")
  student   Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  group     CourseGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  status    String      @default("active")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@unique([studentId, groupId])
  @@map("student_course_group_enrollments")
}

model StudentAnswer {
  id              String           @id @default(uuid())
  sessionId       String           @map("session_id")
  studentId       String           @map("student_id")
  questionId      String           @map("question_id")
  session         ClassroomSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student         Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  question        Question         @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answer          Json
  isCorrect       Boolean          @map("is_correct")
  score           Decimal
  durationSeconds Int?             @map("duration_seconds")
  submittedAt     DateTime         @default(now()) @map("submitted_at")

  @@map("student_answers")
}

model LearningProfile {
  id                    String   @id @default(uuid())
  studentId             String   @map("student_id")
  courseId              String   @map("course_id")
  student               Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course                Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  mastery               Json
  weakPoints            Json     @map("weak_points")
  mistakeReasons        Json     @map("mistake_reasons")
  recommendedPractice   Json     @map("recommended_practice")
  aiConversationSummary String?  @map("ai_conversation_summary")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@unique([studentId, courseId])
  @@map("learning_profiles")
}

model ParentSummary {
  id             String   @id @default(uuid())
  studentId      String   @map("student_id")
  courseId       String   @map("course_id")
  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course         Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  weeklyStatus   String   @map("weekly_status")
  mastered       Json
  needsAttention Json     @map("needs_attention")
  suggestion     String
  generatedAt    DateTime @default(now()) @map("generated_at")

  @@unique([studentId, courseId])
  @@map("parent_summaries")
}

model KnowledgeCategory {
  id        String              @id @default(uuid())
  name      String
  icon      String              @default("folder_open")
  sortOrder Int                 @default(0) @map("sort_order")
  status    String              @default("active")
  deletedAt DateTime?           @map("deleted_at")
  materials KnowledgeMaterial[]
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  @@map("knowledge_categories")
}

model KnowledgeMaterial {
  id               String            @id @default(uuid())
  categoryId       String            @map("category_id")
  category         KnowledgeCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  title            String
  type             String
  subject          String
  grade            String
  size             String?
  pages            Int               @default(0)
  parseStatus      String            @default("parsed") @map("parse_status")
  lifecycleStatus  String            @default("active") @map("lifecycle_status")
  source           String            @default("手动添加")
  chunks           Int               @default(0)
  evidenceCount    Int               @default(0) @map("evidence_count")
  vectorIndexed    Boolean           @default(false) @map("vector_indexed")
  bm25Indexed      Boolean           @default(false) @map("bm25_indexed")
  teacherPinned    Boolean           @default(false) @map("teacher_pinned")
  tags             Json              @default("[]")
  knowledgePoints  Json              @default("[]") @map("knowledge_points")
  retrievalSummary Json?             @map("retrieval_summary")
  evidenceTypes    Json              @default("[]") @map("evidence_types")
  availableActions Json              @default("[]") @map("available_actions")
  usedByCourses    Json              @default("[]") @map("used_by_courses")
  deletedAt        DateTime?         @map("deleted_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  @@map("knowledge_materials")
}
